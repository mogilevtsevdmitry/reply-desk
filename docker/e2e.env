# Тестовое окружение E2E-стенда (CI). Значения — НЕ секреты (заглушки),
# совпадают с контрактом apps/web/e2e/global-setup.ts (rd-e2e-pg, replydesk_e2e).
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://replydesk_e2e:replydesk_e2e@postgres:5432/replydesk_e2e?schema=public
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=e2e-only-secret-not-for-production-0000
JWT_ACCESS_TTL=15m
REFRESH_TTL_DAYS=30
CORS_ORIGINS=http://localhost:3100
LIMIT_FREE=10
LIMIT_START=100
LIMIT_BUSINESS=1000
LLM_PROVIDER=fake
WORKER_EMBEDDED=true
PROMPTS_DIR=/app/prompts
SEED_ON_START=false
# ADR-025: global-setup создаёт 5 пользователей через UI — поднимаем лимиты throttler
THROTTLE_AUTH_LIMIT=200
THROTTLE_DEFAULT_LIMIT=200
