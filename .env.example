# ============================================================
# ReplyDesk — переменные окружения (ядро бэкенда + генерационный конвейер).
# Скопируй в .env и заполни секреты.
# ============================================================

# --- Общее ---
# development | test | production
NODE_ENV=development
# Порт API (NestJS)
PORT=4000

# --- Хранилища ---
# PostgreSQL 16 с расширением pg_trgm (ставится миграцией)
DATABASE_URL=postgresql://replydesk:replydesk@localhost:5432/replydesk?schema=public
# Redis 7: BullMQ-очередь `generation`, pub/sub статусов для SSE, health-check
REDIS_URL=redis://localhost:6379

# --- Аутентификация ---
# Секрет подписи access-JWT, минимум 32 символа. Сгенерировать: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-to-a-random-string-of-32-plus-chars
# Время жизни access-токена (формат ms/jsonwebtoken: 15m, 1h...)
JWT_ACCESS_TTL=15m
# Время жизни refresh-токена в днях (httpOnly cookie + хэш в БД, ADR-016)
REFRESH_TTL_DAYS=30

# --- CORS ---
# Whitelist источников через запятую: bare-metal dev (:3000) + docker compose (:3200)
CORS_ORIGINS=http://localhost:3000,http://localhost:3200

# --- Лимиты генераций по тарифам (в месяц, ADR-002) ---
LIMIT_FREE=10
LIMIT_START=100
LIMIT_BUSINESS=1000

# --- AI-слой и генерационный конвейер ---
# Провайдер LLM: anthropic (прод) | fake (детерминированные ответы без сети — dev/QA, ADR-019)
LLM_PROVIDER=anthropic
# API-ключ Anthropic (обязателен при LLM_PROVIDER=anthropic): https://console.anthropic.com
ANTHROPIC_API_KEY=
# Модель Anthropic для генерации пакета реакции
ANTHROPIC_MODEL=claude-sonnet-4-5
# Порог pg_trgm-похожести кандидатов похожих отзывов, 0..1 (ADR-001)
SIMILARITY_THRESHOLD=0.3
# Запускать BullMQ-воркер внутри процесса API (ADR-020):
# true — удобный dev-режим (по умолчанию); в проде API ставит false,
# воркер работает отдельным процессом: node dist/worker.js
WORKER_EMBEDDED=true
# Необязательно: явный путь к папке промптов (по умолчанию prompts/ ищется автоматически)
# PROMPTS_DIR=./prompts

# --- Frontend (apps/web) ---
# Базовый URL API для браузера. ВАЖНО (BUG-003): бакируется в JS на этапе
# `next build` — в Docker передаётся как build-arg, при смене URL образ web
# пересобирается (docs/devops/DEPLOY.md). Дефолт — compose-стенд (api на :4200);
# bare-metal dev (`pnpm dev`) использует встроенный фолбэк http://localhost:4000/api/v1.
NEXT_PUBLIC_API_URL=http://localhost:4200/api/v1

# ============================================================
# Docker Compose (docker/compose.yaml) — запуск из корня репо:
#   docker compose -f docker/compose.yaml --env-file .env up --build -d
# Хост-порты с дефолтами (ADR-027): не пересекаются с bare-dev (:3000/:4000)
# ============================================================
# PostgreSQL внутри compose (DATABASE_URL для контейнеров собирается автоматически)
POSTGRES_USER=replydesk
POSTGRES_PASSWORD=replydesk-local-change-me
POSTGRES_DB=replydesk
# Публикуемые наружу порты: только web и api
WEB_PORT=3200
API_PORT=4200
# Порты БД наружу открывает только dev-оверрайд (compose.dev.yaml)
PG_PORT=54325
REDIS_PORT=63793
# Прогнать seed (demo@replydesk.ru / Demo12345! + 5 отзывов) при старте migrate-сервиса
SEED_ON_START=false
