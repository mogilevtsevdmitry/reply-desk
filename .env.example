# ============================================================
# ReplyDesk — переменные окружения (задача 2.1: ядро бэкенда).
# Скопируй в .env и заполни секреты. Переменные LLM/BullMQ-воркера
# (ANTHROPIC_API_KEY, ANTHROPIC_MODEL, SIMILARITY_THRESHOLD)
# добавит задача 2.2.
# ============================================================

# --- Общее ---
# development | test | production
NODE_ENV=development
# Порт API (NestJS)
PORT=4000

# --- Хранилища ---
# PostgreSQL 16 с расширением pg_trgm (ставится миграцией)
DATABASE_URL=postgresql://replydesk:replydesk@localhost:5432/replydesk?schema=public
# Redis 7 (health-check сейчас, BullMQ — в задаче 2.2)
REDIS_URL=redis://localhost:6379

# --- Аутентификация ---
# Секрет подписи access-JWT, минимум 32 символа. Сгенерировать: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-to-a-random-string-of-32-plus-chars
# Время жизни access-токена (формат ms/jsonwebtoken: 15m, 1h...)
JWT_ACCESS_TTL=15m
# Время жизни refresh-токена в днях (httpOnly cookie + хэш в БД, ADR-016)
REFRESH_TTL_DAYS=30

# --- CORS ---
# Whitelist источников через запятую (фронтенд dev-сервер)
CORS_ORIGINS=http://localhost:3000

# --- Лимиты генераций по тарифам (в месяц, ADR-002) ---
LIMIT_FREE=10
LIMIT_START=100
LIMIT_BUSINESS=1000

# --- Frontend (apps/web) ---
# Базовый URL API для браузера
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
